# Copy this file to .env and fill in your real VPS values.
VPS_HOST=your-vps-ip-or-domain
VPS_PORT=22
VPS_USER=root
# Local use:
VPS_SSH_KEY_PATH=C:\\Users\\your-user\\.ssh\\id_rsa
# Render or other hosted deploys:
VPS_SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END OPENSSH PRIVATE KEY-----
VPS_FILE_ROOT=/home/ubuntu
